---
import { ShieldCheck, Droplets, Sparkles, Sun, Palette, Layers, MessageCircle, CheckCircle2 } from 'lucide-react';
import { Image } from 'astro:assets';
import hpcImage from '../assets/labocosmetica-hpc-pro.jpg';

const manufacturers = [
    "Labocosmetica",
    "Gtechniq",
    "Sonax",
    "Koch Chemie",
    "Safe Shield"
];

const criteria = [
    {
        icon: Palette,
        title: "Lackfarbe",
        description: "Helle und dunkle Lacke stellen unterschiedliche Anforderungen an Optik und Tiefenglanz."
    },
    {
        icon: Layers,
        title: "Lackhärte",
        description: "Weiche Klarlacke benötigen andere Beschichtungen als harte Lacke. Wir wählen passend."
    },
    {
        icon: Sun,
        title: "Fahrzeugnutzung",
        description: "Daily Driver, Garagenwagen oder Showcar – die Beanspruchung entscheidet über die Versiegelung."
    },
    {
        icon: ShieldCheck,
        title: "Lackzustand",
        description: "Neuwagen, gepflegt oder stark beansprucht – die Vorbereitung und Versiegelung richten sich danach."
    }
];
---

<div class="glass-card p-4 md:p-10 rounded-3xl border border-white/10 bg-zinc-900/40 relative overflow-hidden">
    {/* Decorative Background */}
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-red-900/10 blur-[100px] rounded-full -z-10 pointer-events-none"></div>

    <div class="flex flex-col md:flex-row items-center gap-8 mb-12">
        <div class="md:w-1/3 relative group">
             <div class="absolute inset-0 bg-red-600/20 blur-xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
             <Image
                src={hpcImage}
                alt="High-End Keramikversiegelung Anwendung"
                class="rounded-2xl border border-white/10 shadow-2xl relative z-10 w-full object-cover aspect-square"
                widths={[320, 480, 640, 800, 960]}
                sizes="(max-width: 768px) calc(100vw - 2rem), 400px"
             />
        </div>
        <div class="md:w-2/3 text-left">
            <span class="text-red-500 font-bold uppercase tracking-widest text-sm mb-3 block">Individuell abgestimmt</span>
            <h3 class="text-2xl md:text-4xl font-bold text-white mb-4">Keramikversiegelung nach Maß – für jedes Fahrzeug die passende Lösung</h3>
            <p class="text-zinc-400 text-lg leading-relaxed">
                Wir legen uns nicht auf ein Produkt fest. Jede Versiegelung wird individuell auf Ihr Fahrzeug abgestimmt –
                nach Lackfarbe, Lackhärte, Zustand und Nutzung. Das Ergebnis: maximaler Schutz und Tiefenglanz,
                der wirklich zu Ihrem Wagen passt.
            </p>
        </div>
    </div>

    {/* Entscheidungskriterien */}
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-10">
        {criteria.map((item) => (
            <div class="p-6 rounded-2xl border border-white/10 bg-black/30 hover:border-red-500/30 transition-colors">
                <div class="w-12 h-12 bg-zinc-950 rounded-xl flex items-center justify-center mb-4 text-red-500 border border-white/5">
                    <item.icon size={22} strokeWidth={1.5} />
                </div>
                <h4 class="text-lg font-bold text-white mb-2">{item.title}</h4>
                <p class="text-sm text-zinc-400 leading-relaxed">{item.description}</p>
            </div>
        ))}
    </div>

    {/* Hersteller */}
    <div class="p-6 md:p-8 rounded-2xl border border-white/10 bg-black/30 mb-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div>
                <span class="text-xs font-bold text-red-500 uppercase tracking-widest mb-2 block">Unsere Produktpartner</span>
                <h4 class="text-xl md:text-2xl font-bold text-white">Hochwertige Produkte renommierter Hersteller</h4>
                <p class="text-sm text-zinc-400 mt-2 max-w-xl">
                    Wir verarbeiten gezielt die Beschichtung, die am besten zu Ihrem Fahrzeug passt.
                </p>
            </div>
            <ul class="flex flex-wrap gap-2 md:gap-3 md:max-w-md">
                {manufacturers.map((name) => (
                    <li class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/5 text-sm font-bold text-zinc-200">
                        <CheckCircle2 size={14} class="text-red-500" />
                        {name}
                    </li>
                ))}
            </ul>
        </div>
    </div>

    {/* CTA */}
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-6 md:p-8 rounded-2xl border border-red-900/30 bg-gradient-to-br from-red-900/10 to-zinc-900/40">
        <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-red-600/20 border border-red-500/30 flex items-center justify-center text-red-500 shrink-0">
                <MessageCircle size={22} />
            </div>
            <div>
                <h4 class="text-lg md:text-xl font-bold text-white mb-1">Individuelle Beratung statt Standard-Paket</h4>
                <p class="text-sm text-zinc-400">Im persönlichen Gespräch finden wir die beste Versiegelung für Ihren Wagen.</p>
            </div>
        </div>
        <a href="https://wa.me/491633845081" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-red-700 hover:bg-red-600 text-white rounded-xl font-bold transition-colors shadow-lg shadow-red-900/20 whitespace-nowrap">
            Jetzt anfragen
        </a>
    </div>
</div>
