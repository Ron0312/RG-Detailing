---
import Layout from '../layouts/Layout.astro';
import PriceCalculator from '../components/PriceCalculator.jsx';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.jsx';
import ScrollReveal from '../components/ScrollReveal.jsx';
import { ShieldCheck, Droplets, Gem, Sun, Clock, Zap, ArrowRight, CheckCircle2 } from 'lucide-react';
import { Image } from 'astro:assets';
import heroImage from '../assets/labocosmetica-hpc-pro.jpg';
import detailImage from '../assets/keramikversiegelung-mercedes-sl-tensfeld.webp';
import showcaseImage from '../assets/keramikversiegelung-detailing-halle-tensfeld.jpg';

const benefits = [
    {
        icon: ShieldCheck,
        title: "Maximaler Lackschutz",
        description: "Schützt effektiv vor UV-Strahlung, Vogelkot, Insektenresten und aggressiver Chemie. Ihr Lack bleibt makellos."
    },
    {
        icon: Droplets,
        title: "Extremer Hydrophobie-Effekt",
        description: "Wasser perlt einfach ab (selbstreinigender Lotuseffekt). Das Fahrzeug bleibt länger sauber und die Wäsche wird zum Kinderspiel."
    },
    {
        icon: Sun,
        title: "Ultimativer Tiefenglanz",
        description: "Die glasartige Schicht verstärkt die Farbtiefe und Brillanz Ihres Lacks drastisch. Ein dauerhafter 'Wet-Look'."
    },
    {
        icon: Clock,
        title: "Bis zu 60 Monate Standzeit",
        description: "Anders als Wachs (Wochen) hält unsere zertifizierte Keramikversiegelung über Jahre. Mit Garantie."
    }
];

const processSteps = [
    {
        step: "01",
        title: "Intensive Vorbereitung",
        description: "Gründliche Handwäsche, chemische Dekontamination (Flugrost, Teer) und Kneten für eine klinisch reine Oberfläche."
    },
    {
        step: "02",
        title: "Mehrstufige Defektkorrektur",
        description: "Entfernung von Kratzern und Swirls durch Polieren. Nur ein perfekter Lack kann perfekt versiegelt werden."
    },
    {
        step: "03",
        title: "Entfettung & Primer",
        description: "Spezielle Reinigungslösung entfernt letzte Politurreste für die optimale chemische Anbindung der Keramik."
    },
    {
        step: "04",
        title: "Coating Applikation",
        description: "Individuelle Applikation der Keramikversiegelung – wir wählen das passende Produkt anhand von Lackzustand, Farbe und Nutzung Ihres Fahrzeugs aus."
    },
    {
        step: "05",
        title: "Aushärtung (Curing)",
        description: "Aushärtung unter Infrarot-Strahlern in unserer kontrollierten Halle für maximale Härte und Beständigkeit."
    }
];

const faqItems = [
    {
        question: "Was ist der Unterschied zu Wachs oder Nanoversiegelung?",
        answer: "Während Wachs nur aufliegt und schnell verdunstet, geht eine echte Keramikversiegelung (oft fälschlich 'Nanoversiegelung' genannt) eine feste chemische Bindung ein. Sie ist extrem hart, hitzebeständig und hält Jahre statt Wochen."
    },
    {
        question: "Wie lange muss das Auto bei euch bleiben?",
        answer: "Für eine hochwertige Keramikversiegelung benötigen wir Ihr Fahrzeug in der Regel 3-4 Werktage, um die Versiegelung perfekt aushärten zu lassen."
    },
    {
        question: "Kann ich danach in die Waschanlage?",
        answer: "Ja, aber wir empfehlen Handwäsche, um den Glanz maximal zu erhalten. Textilwaschanlagen sind okay, vermeiden Sie aber aggressive Bürsten."
    },
    {
        question: "Gibt es eine Garantie?",
        answer: "Ja, als zertifizierter Detailer erhalten Sie eine schriftliche Garantiekarte und ein Pflegeheft für Ihre Versiegelung."
    },
    {
        question: "Versiegeln Sie auch Wohnmobile?",
        answer: "Ja, wir bieten auch spezielle Wohnwagen Keramikversiegelung und Wohnmobil Keramikversiegelung an. Dies schützt das GFK-Dach vor Auskreidung und erleichtert die Reinigung von Regenstreifen massiv."
    }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Keramikversiegelung Schleswig-Holstein",
  "provider": {
    "@type": "AutoDetailing",
    "name": "RG Detailing",
    "image": "https://rg-detailing.de/logo.png"
  },
  "description": "Zertifizierte High-End Keramikversiegelung – individuell auf Ihr Fahrzeug abgestimmt. Wir verarbeiten hochwertige Produkte von Labocosmetica, Gtechniq, Sonax, Koch Chemie und Safe Shield. Bis zu 5 Jahre Lackschutz und extremer Tiefenglanz.",
  "areaServed": "Schleswig-Holstein",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Keramikversiegelung",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Individuelle Keramikversiegelung – auf Fahrzeug, Lack und Nutzung abgestimmt"
        }
      }
    ]
  }
};
---

<Layout
    title="Keramikversiegelung Schleswig-Holstein | High-End Lackschutz"
    description="Zertifizierte Keramikversiegelung von RG Detailing – individuell auf Ihr Fahrzeug abgestimmt. Wir verarbeiten hochwertige Produkte von Labocosmetica, Gtechniq, Sonax, Koch Chemie und Safe Shield."
    schema={schema}
>
    {/* HERO SECTION */}
    <div class="relative min-h-[70vh] flex items-center justify-center overflow-hidden bg-black">
        <div class="absolute inset-0 z-0">
             <Image
                src={heroImage}
                alt="High-End Keramikversiegelung Applikation"
                class="w-full h-full object-cover opacity-50"
                loading="eager"
                fetchpriority="high"
                format="avif"
             />
             <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
             <div class="absolute inset-0 bg-red-900/10 mix-blend-overlay"></div>
        </div>

        <div class="container mx-auto px-4 z-20 text-center pt-20">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 backdrop-blur-md mb-8 animate-fade-in-up">
                <ShieldCheck size={16} class="text-red-500" />
                <span class="text-xs md:text-sm font-bold text-red-400 uppercase tracking-widest">Der ultimative Lackschutz</span>
            </div>

            <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-6 text-white tracking-tight md:tracking-tighter animate-fade-in-up delay-100">
                Keramik<span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700">versiegelung</span>
            </h1>
            <p class="text-base sm:text-lg md:text-2xl text-zinc-300 max-w-3xl mx-auto mb-10 font-light leading-relaxed animate-fade-in-up delay-200">
                Mehr als nur Wachs oder einfache <strong class="text-white font-normal">Nanoversiegelung</strong>. Eine feste molekulare Verbindung für jahrelangen Schutz, extremen Tiefenglanz und einfachste Pflege.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4 animate-fade-in-up delay-300">
                <a href="#rechner" class="px-8 py-4 bg-red-700 hover:bg-red-600 text-white rounded-xl font-bold transition-all shadow-lg hover:shadow-red-900/40 flex items-center justify-center gap-2">
                    Preis berechnen <ArrowRight size={20} />
                </a>
                <a href="#vorteile" class="px-8 py-4 bg-white/5 hover:bg-white/10 text-white border border-white/10 rounded-xl font-bold transition-all backdrop-blur-sm">
                    Mehr erfahren
                </a>
            </div>
        </div>
    </div>

    <main class="w-full overflow-x-hidden">
        {/* BENEFITS GRID */}
        <section id="vorteile" class="section-spacing relative overflow-hidden">
            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-red-900/10 blur-[120px] rounded-full pointer-events-none"></div>

            <div class="container mx-auto px-4 relative z-10">
                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 md:gap-8">
                    {benefits.map((benefit, index) => (
                        <ScrollReveal client:visible delay={index * 100}>
                            <div class="h-full p-6 md:p-8 rounded-3xl bg-zinc-900/50 border border-white/5 hover:border-red-500/30 hover:bg-zinc-900 transition-all group">
                                <div class="w-14 h-14 bg-zinc-950 rounded-2xl flex items-center justify-center mb-6 text-red-500 group-hover:scale-110 transition-transform shadow-inner border border-white/5">
                                    <benefit.icon size={28} strokeWidth={1.5} />
                                </div>
                                <h3 class="text-xl font-bold text-white mb-4">{benefit.title}</h3>
                                <p class="text-zinc-400 leading-relaxed text-sm">
                                    {benefit.description}
                                </p>
                            </div>
                        </ScrollReveal>
                    ))}
                </div>

                {/* QUICK ACTION */}
                <div class="mt-16 text-center animate-fade-in-up delay-500">
                    <p class="text-zinc-400 mb-6 max-w-2xl mx-auto">
                        Sie sind unsicher, welche Versiegelung zu Ihrem Fahrzeug passt? Kein Problem – wir finden gemeinsam die passende Lösung.
                    </p>
                    <a href="#rechner" class="inline-flex items-center gap-3 bg-white/5 hover:bg-white/10 text-white px-8 py-4 rounded-full font-bold border border-white/10 transition-all active:scale-95 backdrop-blur-sm">
                        <Zap size={20} class="text-yellow-500" />
                        <span>Jetzt unverbindlich Preis prüfen</span>
                    </a>
                </div>
            </div>
        </section>

        {/* INDIVIDUAL COATING SECTION */}
        <section class="section-spacing border-y border-white/5 bg-zinc-900/20">
            <div class="container mx-auto px-4">
                <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
                    <div class="lg:w-1/2">
                        <ScrollReveal client:visible>
                            <span class="text-red-500 font-bold uppercase tracking-widest text-sm mb-4 block">Individuell abgestimmt</span>
                            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-6">Keramikversiegelung <br class="hidden sm:inline"/> nach Maß</h2>
                            <p class="text-zinc-400 text-lg leading-relaxed mb-6">
                                Jeder Lack ist anders. Ob hell oder dunkel, weich oder hart, Daily Driver oder Showcar – die passende Versiegelung konfigurieren wir gemeinsam im persönlichen Gespräch, abgestimmt auf Fahrzeug, Lackzustand und Nutzung.
                            </p>
                            <p class="text-zinc-400 text-lg leading-relaxed mb-8">
                                Dafür verarbeiten wir hochwertige Produkte renommierter Hersteller: <strong class="text-white">Labocosmetica</strong>, <strong class="text-white">Gtechniq</strong>, <strong class="text-white">Sonax</strong>, <strong class="text-white">Koch Chemie</strong> und <strong class="text-white">Safe Shield</strong>. So wählen wir für jedes Fahrzeug die beste Lösung – statt ein Produkt auf jeden Lack zu zwingen.
                            </p>
                            <ul class="space-y-4 mb-10">
                                <li class="flex items-center gap-3 text-zinc-300">
                                    <CheckCircle2 class="text-red-500 w-5 h-5" />
                                    <span>Zertifizierte Anwendung vom Profi</span>
                                </li>
                                <li class="flex items-center gap-3 text-zinc-300">
                                    <CheckCircle2 class="text-red-500 w-5 h-5" />
                                    <span>Schriftliche Garantiekarte</span>
                                </li>
                                <li class="flex items-center gap-3 text-zinc-300">
                                    <CheckCircle2 class="text-red-500 w-5 h-5" />
                                    <span>Inklusive jährlichem Pflege-Check</span>
                                </li>
                            </ul>
                            <a href="#rechner" class="inline-flex items-center gap-2 text-white font-bold border-b-2 border-red-500 pb-1 hover:text-red-400 transition-colors">
                                Jetzt Angebot einholen <ArrowRight size={16} />
                            </a>
                        </ScrollReveal>
                    </div>
                    <div class="lg:w-1/2 relative">
                        <div class="absolute inset-0 bg-red-500/20 blur-[100px] rounded-full"></div>
                        <Image
                            src={detailImage}
                            alt="Mercedes 380 SL nach Keramikversiegelung in unserer Halle in Tensfeld – tiefer Lackglanz und Hydrophobie-Effekt"
                            class="relative z-10 rounded-3xl border border-white/10 shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-700"
                            width={800}
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </section>

        {/* PROCESS STEPS */}
        <section class="section-spacing bg-zinc-950">
            <div class="container mx-auto px-4">
                <div class="text-center mb-12 md:mb-20">
                    <span class="text-red-500 font-bold uppercase tracking-widest text-sm">Transparenz</span>
                    <h2 class="text-3xl md:text-5xl font-bold text-white mt-4">Der Weg zur Perfektion</h2>
                </div>

                <div class="relative">
                    <div class="absolute left-[19px] top-0 bottom-0 w-0.5 bg-zinc-800 md:left-1/2 md:-ml-px"></div>

                    <div class="space-y-12">
                        {processSteps.map((item, index) => (
                            <ScrollReveal client:visible delay={index * 100}>
                                <div class={`relative flex items-center md:justify-between ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                                    <div class="hidden md:block w-5/12"></div>

                                    <div class="absolute left-0 md:left-1/2 w-10 h-10 -ml-5 rounded-full border-4 border-zinc-950 bg-red-600 text-white flex items-center justify-center font-bold text-sm shadow-lg z-10">
                                        {index + 1}
                                    </div>

                                    <div class="pl-14 md:pl-0 md:w-5/12">
                                        <div class="bg-zinc-900/50 p-5 md:p-8 rounded-2xl border border-white/5 hover:border-red-500/20 transition-colors">
                                            <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
                                            <p class="text-zinc-400 text-sm leading-relaxed">{item.description}</p>
                                        </div>
                                    </div>
                                </div>
                            </ScrollReveal>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        {/* SHOWCASE */}
        <section class="section-spacing border-y border-white/5 bg-zinc-950">
            <div class="container mx-auto px-4">
                <ScrollReveal client:visible>
                    <div class="text-center mb-12">
                        <span class="text-red-500 font-bold uppercase tracking-widest text-sm">Aus unserer Halle</span>
                        <h2 class="text-3xl md:text-5xl font-bold text-white mt-4">Keramikversiegelung in Aktion</h2>
                        <p class="text-zinc-400 mt-4 max-w-2xl mx-auto">
                            Beispiele aus unserer Werkstatt in Tensfeld – Liebhaberstücke wie Daily Driver behandeln wir mit derselben Sorgfalt.
                        </p>
                    </div>
                </ScrollReveal>
                <ScrollReveal client:visible delay={200}>
                    <Image
                        src={showcaseImage}
                        alt="Mercedes 380 SL Cabrio in der Halle von RG Detailing – hochwertige Lackveredelung & Keramikversiegelung Schleswig-Holstein"
                        class="rounded-3xl border border-white/10 shadow-2xl mx-auto max-w-4xl w-full"
                        width={1600}
                        loading="lazy"
                    />
                </ScrollReveal>
            </div>
        </section>

        {/* FAQ */}
        <section class="section-spacing bg-zinc-900/30 border-y border-white/5">
            <div class="container mx-auto px-4 max-w-3xl">
                <h2 class="text-3xl font-bold text-white text-center mb-12">Häufige Fragen zur Versiegelung</h2>
                <FAQ client:visible items={faqItems} />
            </div>
        </section>

        {/* SOCIAL PROOF */}
        <Reviews limit={3} />

        {/* CTA */}
        <section id="rechner" class="section-spacing relative overflow-hidden">
            <div class="container mx-auto px-4">
                <div class="max-w-5xl mx-auto glass-panel p-8 md:p-12 rounded-3xl border border-red-500/20 bg-zinc-900/80 backdrop-blur-xl relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-96 h-96 bg-red-600/10 blur-[150px] rounded-full pointer-events-none"></div>

                    <div class="text-center mb-12 relative z-10">
                        <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">Investieren Sie in den Werterhalt</h2>
                        <p class="text-zinc-400 max-w-2xl mx-auto text-lg">
                            Wählen Sie Ihr Fahrzeug und erhalten Sie sofort eine unverbindliche Preisschätzung für Ihre Keramikversiegelung.
                        </p>
                    </div>

                    <PriceCalculator client:visible />
                </div>
            </div>
        </section>
    </main>
</Layout>