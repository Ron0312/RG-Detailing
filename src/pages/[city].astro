---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BeforeAfterSlider from '../components/BeforeAfterSlider.jsx';

import Reviews from '../components/Reviews.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PrivacyMap from '../components/PrivacyMap.astro';
import { getSeoContent } from '../lib/seoContent';
import { Image, getImage } from 'astro:assets';
import heroImage from '../assets/rg-detailing_Fahrzeugaufbereitung_Tensfeld_Hero.jpg';
import wohnmobilBefore from '../assets/wohnmobil-before.jpg';
import wohnmobilAfter from '../assets/wohnmobil-after.jpg';
import { Sparkles, ShieldCheck, Droplets, Map, Check, Calendar, Car, Key, Star, ArrowRight, HelpCircle } from 'lucide-react';

export const prerender = true;

export async function getStaticPaths() {
  const cities = await getCollection('cities');
  return cities.map(city => ({
    params: { city: city.data.slug },
    props: { cityEntry: city },
  }));
}

const { cityEntry } = Astro.props;
const { name, metaDescription, introText, geo, distance } = cityEntry.data;
const seoContent = getSeoContent(name, distance);

const optimizedBefore = await getImage({src: wohnmobilBefore, format: 'avif'});
const optimizedAfter = await getImage({src: wohnmobilAfter, format: 'avif'});

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDetailing",
  "name": "RG Detailing",
  "url": `https://rg-detailing.de/${cityEntry.data.slug}`,
  "description": metaDescription,
  "dateModified": new Date().toISOString().split('T')[0],
  "areaServed": {
    "@type": "City",
    "name": name,
    "geo": {
        "@type": "GeoCoordinates",
        "latitude": geo.latitude,
        "longitude": geo.longitude
    }
  },
  "priceRange": "€€-€€€",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Tensfeld",
    "postalCode": "23824",
    "streetAddress": "Dorfstraße 11",
    "addressCountry": "DE",
    "addressRegion": "Schleswig-Holstein"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }
  ],
  "image": "https://rg-detailing.de/logo.png",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Fahrzeugaufbereitung Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Keramikversiegelung"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Lackkorrektur"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Innenraumreinigung"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Muss ich das Auto vorher waschen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein, eine schonende Handwäsche ist bei uns der erste Schritt jeder Aufbereitung. Sie können Ihr Fahrzeug einfach so zu uns bringen, wie es ist."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange dauert eine Keramikversiegelung?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Für ein perfektes Ergebnis sollten Sie mit 2-3 Werktagen rechnen. Dies beinhaltet die gründliche Vorwäsche, mehrstufige Lackkorrektur und die Aushärtezeit der Keramikbeschichtung."
      }
    },
    {
      "@type": "Question",
      "name": "Lohnt sich eine Aufbereitung vor der Leasingrückgabe?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolut. Erfahrungsgemäß sparen unsere Kunden durch eine professionelle Aufbereitung hunderte bis tausende Euro bei der Leasingrückgabe, da Nachzahlungen für Mängel oft deutlich höher ausfallen als die Aufbereitungskosten."
      }
    }
  ]
};

const schema = [localBusinessSchema, faqSchema];

const optimizedHero = await getImage({
    src: heroImage,
    format: 'avif',
    width: 640,
    quality: 60,
});
---

<Layout title={`Fahrzeugaufbereitung ${name} | RG Detailing`} description={metaDescription} schema={schema} preloadImage={optimizedHero.src}>

    <div class="absolute top-24 left-0 w-full z-30 container mx-auto px-4">
        <Breadcrumbs crumbs={[
            { label: 'Startseite', href: '/' },
            { label: `Aufbereitung ${name}`, href: `/${cityEntry.data.slug}` }
        ]} />
    </div>

    {/* City Hero */}
    <div class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
        {/* Background Gradients */}
        <div class="absolute inset-0 bg-black z-0">
             <Image
                src={heroImage}
                alt={`Premium Fahrzeugaufbereitung für Kunden aus ${name}`}
                class="w-full h-full object-cover opacity-40"
                loading="eager"
                fetchpriority="high"
                format="avif"
                quality={60}
                widths={[640, 768, 1024, 1280, 1536, 1920]}
                sizes="100vw"
             />
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/60 to-black z-10"></div>
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-red-900/20 blur-[120px] rounded-full z-0 animate-pulse"></div>

        <div class="container mx-auto px-4 z-20 text-center relative pt-20 pb-32">
            <h1 class="text-4xl md:text-6xl font-bold mb-6 text-white tracking-tight leading-tight">
                Premium Fahrzeugaufbereitung <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-700">für {name}</span>
            </h1>
            <p class="text-lg md:text-xl text-zinc-400 max-w-3xl mx-auto leading-relaxed mb-10">
                {introText}
            </p>
             <div class="flex flex-col sm:flex-row justify-center items-center gap-6 mb-8">
                <a href="#rechner" class="group relative px-8 py-5 bg-red-700 rounded-2xl font-bold text-white overflow-hidden transition-all hover:scale-105 hover:shadow-[0_0_50px_-10px_rgba(220,38,38,0.6)] w-full sm:w-auto">
                    <span class="relative z-10 flex items-center justify-center gap-2">Kostenlos Preis berechnen <ArrowRight className="w-5 h-5" /></span>
                    <div class="absolute inset-0 bg-gradient-to-r from-red-600 to-red-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </a>
                 <span class="flex items-center gap-2 text-zinc-300 bg-zinc-900/50 px-4 py-2 rounded-lg border border-white/5 backdrop-blur-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Nur {distance} Anfahrt von {name}
                 </span>
            </div>
        </div>
    </div>

    <main class="container mx-auto px-4 py-20 relative z-20">

        {/* Why RG Card */}
        <div class="glass-panel p-8 md:p-12 rounded-3xl max-w-6xl mx-auto shadow-2xl mb-32 border border-white/5 bg-zinc-950/80 backdrop-blur-xl">
            <div class="grid lg:grid-cols-5 gap-12 items-center">
                <div class="lg:col-span-3">
                    <h2 class="text-3xl font-bold mb-6 text-white">Lohnt sich der Weg aus {name}?</h2>
                    <p class="text-zinc-400 mb-8 leading-relaxed text-lg">
                        Definitiv. In {name} finden Sie vielleicht viele Waschanlagen und Standard-Aufbereiter.
                        Doch RG Detailing in Tensfeld ist eine <strong>Manufaktur für Fahrzeugpflege</strong>.
                        Wir nehmen uns die Zeit, die Ihr Fahrzeug verdient – oft 20-30 Stunden für eine Lackkorrektur.
                        Für kompromisslose <strong>High-End Qualität</strong> und Werterhalt lohnt sich der Weg immer.
                    </p>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center text-red-500 shrink-0 border border-red-500/20">
                                <Check className="w-5 h-5" />
                            </div>
                            <span class="text-zinc-300">Zertifizierter <strong class="text-white">Labocosmetica Detailer</strong> (Excellence Center)</span>
                        </li>
                        <li class="flex items-center gap-4">
                             <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center text-red-500 shrink-0 border border-red-500/20">
                                <Check className="w-5 h-5" />
                             </div>
                            <span class="text-zinc-300">Expertise für <strong class="text-white">Sportwagen, Oldtimer & Alltagsfahrzeuge</strong></span>
                        </li>
                         <li class="flex items-center gap-4">
                             <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center text-red-500 shrink-0 border border-red-500/20">
                                <Check className="w-5 h-5" />
                             </div>
                            <span class="text-zinc-300">Hygienische Innenraumreinigung (170°C Dampf)</span>
                        </li>
                         <li class="flex items-center gap-4">
                             <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center text-red-500 shrink-0 border border-red-500/20">
                                <Check className="w-5 h-5" />
                             </div>
                            <span class="text-zinc-300">Halle alarmgesichert & videoüberwacht</span>
                        </li>
                    </ul>
                </div>
                <div class="lg:col-span-2 bg-zinc-900/50 p-3 rounded-2xl border border-white/5 h-full flex flex-col justify-between">
                    {/* Google Map Embed */}
                    <div class="w-full aspect-square md:aspect-video lg:aspect-square rounded-xl overflow-hidden relative bg-zinc-800 mb-4 border border-white/5 shadow-inner">
                         <PrivacyMap
                            src="https://maps.google.com/maps?q=RG+Detailing+Tensfeld&t=&z=13&ie=UTF8&iwloc=&output=embed"
                            title={`Karte von ${name} nach Tensfeld`}
                         />
                    </div>
                    <a
                        href={`https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(name)}&destination=RG+Detailing,+Dorfstraße+11,+23824+Tensfeld`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full py-4 bg-red-600 hover:bg-red-700 text-white rounded-xl text-center font-bold transition-all shadow-lg shadow-red-900/20 hover:shadow-red-900/40 flex items-center justify-center gap-3 group"
                    >
                        <Map className="w-5 h-5" />
                        Route berechnen ({distance})
                        <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                    </a>
                </div>
            </div>
        </div>

        {/* High End Promise Section */}
        <div class="grid md:grid-cols-2 gap-8 mb-32">
             <div class="glass-panel p-8 rounded-3xl border border-white/5 bg-zinc-950/50 flex flex-col justify-center">
                 <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 rounded-full bg-zinc-900 flex items-center justify-center border border-white/10">
                        <ShieldCheck className="text-white w-6 h-6" />
                    </div>
                    <h3 class="text-xl font-bold text-white">Sicherheit & Diskretion</h3>
                 </div>
                 <p class="text-zinc-400 leading-relaxed">
                    Ihr Fahrzeug ist bei uns in besten Händen. Unsere Halle ist nicht öffentlich einsehbar, voll alarmgesichert und videoüberwacht. Wir behandeln jedes Kundenfahrzeug mit absoluter Diskretion.
                 </p>
             </div>
             <div class="glass-panel p-8 rounded-3xl border border-white/5 bg-zinc-950/50 flex flex-col justify-center">
                 <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 rounded-full bg-zinc-900 flex items-center justify-center border border-white/10">
                        <Car className="text-white w-6 h-6" />
                    </div>
                    <h3 class="text-xl font-bold text-white">Alle Marken & Modelle</h3>
                 </div>
                 <p class="text-zinc-400 leading-relaxed">
                    Ob Luxus-Sportwagen, geliebter Oldtimer oder täglicher Begleiter – wir behandeln jedes Fahrzeug mit der gleichen Sorgfalt und Präzision.
                 </p>
             </div>
        </div>

        {/* Services Grid optimized for Location */}
        <div class="mb-32">
            <div class="text-center mb-16">
                <span class="text-red-500 font-bold uppercase tracking-widest text-xs block mb-2">Full Service Detailing</span>
                <h2 class="text-3xl md:text-5xl font-bold text-white">Unsere Expertise für {name}</h2>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <a href="/#leistungen" class="glass-card p-10 rounded-3xl group hover:bg-zinc-900/80 cursor-pointer flex flex-col items-center text-center border border-white/5 hover:border-red-500/30 transition-all shadow-xl hover:shadow-red-900/10 h-full">
                    <div class="mb-8 w-20 h-20 rounded-2xl bg-gradient-to-br from-zinc-800 to-zinc-900 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 border border-white/5 shadow-inner">
                        <Sparkles className="w-10 h-10 text-white group-hover:text-red-500 transition-colors" />
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-4">Lackkorrektur</h3>
                    <p class="text-zinc-400 text-base leading-relaxed">Entfernung von Kratzern, Swirls und Hologrammen. Wir holen den Neuwagen-Glanz zurück nach {name}.</p>
                </a>
                 <a href="/#leistungen" class="glass-card p-10 rounded-3xl group hover:bg-zinc-900/80 cursor-pointer flex flex-col items-center text-center border border-white/5 hover:border-red-500/30 transition-all shadow-xl hover:shadow-red-900/10 h-full">
                    <div class="mb-8 w-20 h-20 rounded-2xl bg-gradient-to-br from-zinc-800 to-zinc-900 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 border border-white/5 shadow-inner">
                        <ShieldCheck className="w-10 h-10 text-white group-hover:text-red-500 transition-colors" />
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-4">Keramikversiegelung</h3>
                    <p class="text-zinc-400 text-base leading-relaxed">Langzeitschutz bis zu 5 Jahren. Hydrophober Effekt und extremer Tiefenglanz für Ihr Fahrzeug.</p>
                </a>
                 <a href="/#leistungen" class="glass-card p-10 rounded-3xl group hover:bg-zinc-900/80 cursor-pointer flex flex-col items-center text-center border border-white/5 hover:border-red-500/30 transition-all shadow-xl hover:shadow-red-900/10 h-full">
                    <div class="mb-8 w-20 h-20 rounded-2xl bg-gradient-to-br from-zinc-800 to-zinc-900 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 border border-white/5 shadow-inner">
                        <Droplets className="w-10 h-10 text-white group-hover:text-red-500 transition-colors" />
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-4">Innenraum Wellness</h3>
                    <p class="text-zinc-400 text-base leading-relaxed">Tiefenreinigung mit 170°C Trockendampf. Hygienisch rein ohne Chemie – ideal für Familien.</p>
                </a>
            </div>
        </div>

        {/* Process Section */}
        <div class="mb-32 relative">
             <div class="text-center mb-20">
                <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white">Der Weg zum perfekten Glanz</h2>
                <p class="text-zinc-400 max-w-2xl mx-auto text-lg">Unkompliziert und transparent. So einfach kommen Sie zu Ihrem Termin bei RG Detailing.</p>
            </div>

            {/* Connecting Line (Desktop) */}
            <div class="hidden md:block absolute top-[220px] left-[15%] right-[15%] h-0.5 bg-gradient-to-r from-zinc-800 via-zinc-700 to-zinc-800 z-0"></div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 relative z-10">
                <div class="glass-card p-8 rounded-3xl text-center border border-white/5 hover:-translate-y-2 transition-transform duration-300 bg-zinc-950/50 backdrop-blur-md">
                     <div class="w-14 h-14 bg-zinc-900 rounded-2xl flex items-center justify-center mx-auto mb-6 text-white font-bold text-xl border border-white/10 shadow-lg relative z-10">
                        <span class="text-red-500">1</span>
                     </div>
                     <Calendar className="w-8 h-8 text-zinc-300 mx-auto mb-4" />
                     <h3 class="font-bold text-white text-lg mb-2">Termin</h3>
                     <p class="text-sm text-zinc-400 leading-relaxed">Anfrage online oder per WhatsApp stellen.</p>
                </div>
                <div class="glass-card p-8 rounded-3xl text-center border border-white/5 hover:-translate-y-2 transition-transform duration-300 bg-zinc-950/50 backdrop-blur-md">
                     <div class="w-14 h-14 bg-zinc-900 rounded-2xl flex items-center justify-center mx-auto mb-6 text-white font-bold text-xl border border-white/10 shadow-lg relative z-10">
                        <span class="text-red-500">2</span>
                     </div>
                     <Car className="w-8 h-8 text-zinc-300 mx-auto mb-4" />
                     <h3 class="font-bold text-white text-lg mb-2">Anreise</h3>
                     <p class="text-sm text-zinc-400 leading-relaxed">Nur {distance} Fahrt von {name} zu uns.</p>
                </div>
                <div class="glass-card p-8 rounded-3xl text-center border border-white/5 hover:-translate-y-2 transition-transform duration-300 bg-zinc-950/50 backdrop-blur-md">
                     <div class="w-14 h-14 bg-zinc-900 rounded-2xl flex items-center justify-center mx-auto mb-6 text-white font-bold text-xl border border-white/10 shadow-lg relative z-10">
                        <span class="text-red-500">3</span>
                     </div>
                     <Sparkles className="w-8 h-8 text-zinc-300 mx-auto mb-4" />
                     <h3 class="font-bold text-white text-lg mb-2">Transformation</h3>
                     <p class="text-sm text-zinc-400 leading-relaxed">Wir bringen Lack und Interieur auf Hochglanz.</p>
                </div>
                 <div class="glass-card p-8 rounded-3xl text-center border border-white/5 hover:-translate-y-2 transition-transform duration-300 bg-zinc-950/50 backdrop-blur-md">
                     <div class="w-14 h-14 bg-zinc-900 rounded-2xl flex items-center justify-center mx-auto mb-6 text-white font-bold text-xl border border-white/10 shadow-lg relative z-10">
                        <span class="text-red-500">4</span>
                     </div>
                     <Star className="w-8 h-8 text-zinc-300 mx-auto mb-4" />
                     <h3 class="font-bold text-white text-lg mb-2">Abholung</h3>
                     <p class="text-sm text-zinc-400 leading-relaxed">Begeistert sein vom Neuwagen-Zustand.</p>
                </div>
            </div>
        </div>

        {/* Proof */}
        <div class="mb-32">
             <h2 class="text-3xl md:text-5xl font-bold text-center mb-16 text-white">Ergebnisse, die überzeugen</h2>
             <div class="max-w-5xl mx-auto border border-white/10 rounded-3xl overflow-hidden shadow-2xl">
                 <BeforeAfterSlider
                    client:visible
                    beforeImage={optimizedBefore.src}
                    afterImage={optimizedAfter.src}
                    alt="Aufbereitung Vorher Nachher Vergleich"
                />
             </div>
        </div>

        {/* SEO Content Section */}
        <div class="mb-32 max-w-4xl mx-auto">
            <div class="glass-card p-8 md:p-16 rounded-3xl border border-white/5 bg-zinc-950/50 backdrop-blur-md shadow-2xl">
                 <h2 class="text-3xl font-bold text-white mb-8">{seoContent.title}</h2>
                 <div class="prose prose-invert prose-lg text-zinc-400 leading-relaxed max-w-none" set:html={seoContent.content} />
            </div>
        </div>

        {/* Reviews Section */}
        <div class="mb-32">
            <Reviews limit={4} />
        </div>

        {/* FAQ Section */}
        <div class="mb-32 max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12 text-white">Häufige Fragen aus {name}</h2>
            <div class="space-y-4">
                <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-3">
                        <HelpCircle className="w-5 h-5 text-red-500" />
                        Muss ich das Auto vorher waschen?
                    </h3>
                    <p class="text-zinc-400 leading-relaxed pl-8">
                        Nein, eine schonende Handwäsche ist bei uns der erste Schritt jeder Aufbereitung. Sie können Ihr Fahrzeug einfach so zu uns bringen, wie es ist.
                    </p>
                </div>
                 <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-3">
                        <HelpCircle className="w-5 h-5 text-red-500" />
                        Wie lange dauert eine Keramikversiegelung?
                    </h3>
                    <p class="text-zinc-400 leading-relaxed pl-8">
                        Für ein perfektes Ergebnis sollten Sie mit 2-3 Werktagen rechnen. Dies beinhaltet die gründliche Vorwäsche, mehrstufige Lackkorrektur und die Aushärtezeit der Keramikbeschichtung.
                    </p>
                </div>
                 <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-3">
                        <HelpCircle className="w-5 h-5 text-red-500" />
                        Lohnt sich eine Aufbereitung vor der Leasingrückgabe?
                    </h3>
                    <p class="text-zinc-400 leading-relaxed pl-8">
                        Absolut. Erfahrungsgemäß sparen unsere Kunden durch eine professionelle Aufbereitung hunderte bis tausende Euro bei der Leasingrückgabe, da Nachzahlungen für Mängel oft deutlich höher ausfallen als die Aufbereitungskosten.
                    </p>
                </div>
            </div>
        </div>

        {/* CTA — Links to main page calculator instead of loading 55KB React bundle */}
        <div id="rechner" class="glass-panel p-8 md:p-12 rounded-3xl border border-red-900/30 relative overflow-hidden text-center">
             <div class="absolute top-0 right-0 w-64 h-64 bg-red-900/20 blur-[80px] rounded-full pointer-events-none"></div>
             <div class="relative z-10">
                 <h2 class="text-3xl font-bold mb-4 text-white">Ihr persönliches Angebot</h2>
                 <p class="text-zinc-400 mb-8 max-w-lg mx-auto">In nur 3 Klicks erfahren Sie, was die Aufbereitung für Ihr Fahrzeug kostet. 100 % kostenlos und unverbindlich.</p>
                 <div class="flex flex-col sm:flex-row justify-center gap-4">
                     <a href="/#rechner" class="group relative px-8 py-5 bg-red-700 rounded-2xl font-bold text-white overflow-hidden transition-all hover:scale-105 hover:shadow-[0_0_50px_-10px_rgba(220,38,38,0.6)]">
                         <span class="relative z-10 flex items-center justify-center gap-2">Kostenlos Preis berechnen <ArrowRight className="w-5 h-5" /></span>
                         <div class="absolute inset-0 bg-gradient-to-r from-red-600 to-red-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
